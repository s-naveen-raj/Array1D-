import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) 
    {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int a[]=new int[n];
        for(int i=0;i<n;i++)
        a[i]=sc.nextInt();
        int k=sc.nextInt();
        
        for(int i=0;i<n-1;i++)
        {
            if(a[i]+a[i+1]==k)
            System.out.print(i+" "+(i+1));
        }
    }
}
