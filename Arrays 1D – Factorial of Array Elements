import java.io.*;
import java.util.*;

public class Solution 
{
    public static void main(String[] args) 
    {
      Scanner sc=new Scanner(System.in);
      int n=sc.nextInt();
      int a[]=new int[n];
      for(int i=0;i<n;i++)
      a[i]=sc.nextInt();
      int fact=1;
      for(int i=0;i<n;i++)
      {
        fact=1;
        for(int j=a[i];j>=1;j--)
       {
         fact*=j;
       }
       System.out.print(fact+" ");
      } 
       
    }
}
